# VITE_SUPABASE_URL: your Supabase project's API URL.
# Find it in your Supabase project: Settings -> API -> Project URL.
VITE_SUPABASE_URL=

# VITE_SUPABASE_ANON_KEY: your Supabase project's public "anon" key.
# Find it in your Supabase project: Settings -> API -> Project API keys -> anon public.
# This key is safe to expose in the browser -- it has no special privileges on
# its own. All real access control happens via Row Level Security policies
# (see supabase/schema.sql), not by keeping this key secret.
VITE_SUPABASE_ANON_KEY=

# The Edge Function in supabase/functions/create-admin needs its own
# privileged key (SUPABASE_SERVICE_ROLE_KEY), but that must NEVER go in this
# file or get a VITE_ prefix -- doing so would ship it to the browser. Set it
# only as a Supabase project secret when deploying the function:
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
